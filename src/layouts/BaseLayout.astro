---
import '../styles/global.css';

const {
  title = '石ころノート',
  description = '石ころノート',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => `${base}/${path}`.replace(/\/+/g, '/');
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <aside class="sidebar">
        <a class="logo" href={url()}>石ころノート</a>

        <nav class="nav-section" aria-label="Main navigation">
          <h2>Navigate</h2>
          <a href={url('knowledge/')}>Knowledge</a>
          <a href={url('knowledge/?type=term')}>Terms</a>
          <a href={url('knowledge/?type=guide')}>Guides</a>
          <a href={url('knowledge/?type=memo')}>Memos</a>
        </nav>

        <nav class="nav-section" aria-label="Categories">
          <h2>Categories</h2>
          <a href={url('knowledge/?category=Tech')}>Tech</a>
          <a href={url('knowledge/?category=Work')}>Work</a>
          <a href={url('knowledge/?category=Game')}>Game</a>
          <a href={url('knowledge/?category=Tools')}>Tools</a>
          <a href={url('knowledge/?category=Thinking')}>Thinking</a>
        </nav>
      </aside>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
