---
import '../styles/global.css';

const {
  title = '石ころノート',
  description = '石ころノート',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => `${base}/${path}`.replace(/\/+/g, '/');
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="logo" href={url()}>石ころノート</a>
      <nav class="top-nav" aria-label="Main navigation">
        <a href={url('knowledge/')}>一覧</a>
        <a href={url('knowledge/?category=Tech')}>技術</a>
        <a href={url('knowledge/?category=Work')}>業務</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
