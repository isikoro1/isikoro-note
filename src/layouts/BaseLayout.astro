---
import '../styles/global.css';

const {
  title = '石ころノート',
  description = '石ころノート',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => `${base}/${path}`.replace(/\/+/g, '/');
const currentQuery = Astro.url.searchParams.get('q') ?? '';
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="logo" href={url()}>石ころノート</a>
      <form class="site-search" action={url()} method="get" role="search">
        <input id="site-search" name="q" type="search" value={currentQuery} placeholder="調べたい単語で検索" />
        <button type="submit">検索</button>
      </form>
      <nav class="top-nav" aria-label="Main navigation">
        <a href={url('feedback/')}>誤り指摘</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
