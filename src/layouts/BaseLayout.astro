---
import '../styles/global.css';

const {
  title = '石ころノート',
  description = '石ころノート',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => `${base}/${path}`.replace(/\/+/g, '/');
const currentQuery = Astro.url.searchParams.get('q') ?? '';
const issueUrl = 'https://github.com/isikoro1/isikoro-note/issues/new?title=%E7%9F%B3%E3%81%93%E3%82%8D%E3%83%8E%E3%83%BC%E3%83%88%E3%81%B8%E3%81%AE%E6%8C%87%E6%91%98&body=%E5%AF%BE%E8%B1%A1%E3%83%9A%E3%83%BC%E3%82%B8%3A%20%0A%0A%E6%8C%87%E6%91%98%E5%86%85%E5%AE%B9%3A%20%0A%0A%E5%8F%82%E8%80%83URL%3A%20';
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="logo" href={url()}>石ころノート</a>
      <form class="site-search" action={url()} method="get" role="search">
        <input id="site-search" name="q" type="search" value={currentQuery} placeholder="調べたい単語で検索" />
        <button type="submit">検索</button>
      </form>
      <a class="feedback-link" href={issueUrl} target="_blank" rel="noopener">誤り指摘</a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>