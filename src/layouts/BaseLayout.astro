---
import '../styles/global.css';

const {
  title = 'isikorog note',
  description = '技術・開発・ゲーム・仕事の知識を検索しやすく整理する個人ナレッジベース。',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <aside class="sidebar">
        <a class="logo" href={base}>isikorog note</a>
        <p class="description">検索・リンク・分類で育てる個人ナレッジベース。</p>

        <nav class="nav-section" aria-label="Main navigation">
          <h2>Navigate</h2>
          <a href={`${base}knowledge/`}>Knowledge</a>
          <a href={`${base}knowledge/?type=term`}>Terms</a>
          <a href={`${base}knowledge/?type=guide`}>Guides</a>
          <a href={`${base}knowledge/?type=memo`}>Memos</a>
        </nav>

        <nav class="nav-section" aria-label="Categories">
          <h2>Categories</h2>
          <a href={`${base}knowledge/?category=Tech`}>Tech</a>
          <a href={`${base}knowledge/?category=Work`}>Work</a>
          <a href={`${base}knowledge/?category=Game`}>Game</a>
          <a href={`${base}knowledge/?category=Tools`}>Tools</a>
          <a href={`${base}knowledge/?category=Thinking`}>Thinking</a>
        </nav>
      </aside>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
