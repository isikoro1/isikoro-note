---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => `${base}/${path}`.replace(/\/+/g, '/');
const entries = Object.entries(import.meta.glob('../content/knowledge/**/*.md', { eager: true }));

const notes = entries
  .map(([path, mod]: [string, any]) => {
    const slug = path.replace('../content/knowledge/', '').replace(/\.md$/, '');
    return {
      slug,
      section: getSection(slug),
      ...mod.frontmatter,
    };
  })
  .sort((a: any, b: any) => String(a.title ?? '').localeCompare(String(b.title ?? ''), 'ja'));

function getSection(slug: string) {
  if (slug.startsWith('work/finance/')) return '業務 / 金融ドメイン';
  if (slug.startsWith('tech/java/')) return '技術 / Java';
  if (slug.startsWith('tech/web/')) return '技術 / Web';
  if (slug.startsWith('tech/frontend/')) return '技術 / フロントエンド';
  if (slug.startsWith('tech/database/')) return '技術 / データベース';
  if (slug.startsWith('tech/architecture/')) return '技術 / アーキテクチャ';
  if (slug.startsWith('tools/')) return 'ツール';
  if (slug.startsWith('game/')) return 'ゲーム';
  if (slug.startsWith('life/')) return '生活';
  if (slug.startsWith('routes/')) return '学習ルート';
  return 'その他';
}

const sectionOrder = [
  '技術 / Java',
  '技術 / Web',
  '技術 / フロントエンド',
  '技術 / データベース',
  '技術 / アーキテクチャ',
  '業務 / 金融ドメイン',
  '学習ルート',
  'ツール',
  'ゲーム',
  '生活',
  'その他',
];

const groups = sectionOrder
  .map((section) => ({
    section,
    notes: notes.filter((note: any) => note.section === section),
  }))
  .filter((group) => group.notes.length > 0);
---
<BaseLayout title="石ころノート">
  <section class="notice-box">
    誤り指摘・要望・追加してほしい項目がある場合は、<a href={url('feedback/')}>誤り指摘フォーム</a>から送信できます。
  </section>

  <section id="results" class="link-index search-results" aria-live="polite"></section>

  <section class="index-sections">
    {groups.map((group) => (
      <section class="index-section">
        <h2>{group.section} <span class="count">({group.notes.length})</span></h2>
        <ul class="link-index">
          {group.notes.map((note: any) => (
            <li>
              <a href={url(`knowledge/${note.slug}/`)}>{note.title}</a>
              {note.summary && <span>{note.summary}</span>}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>

  <script define:vars={{ base }}>
    const searchBase = `${base}/`.replace(/\/+/g, '/');
    const input = document.querySelector('#site-search');
    const results = document.querySelector('#results');
    let docs = [];

    const normalize = (value) => String(value ?? '').toLowerCase();
    const makeUrl = (path) => `${searchBase}${path}`.replace(/\/+/g, '/');

    const renderResults = (query) => {
      const normalizedQuery = normalize(query).trim();
      if (!results || !normalizedQuery) {
        if (results) results.innerHTML = '';
        return;
      }

      const matched = docs
        .filter((doc) => normalize([
          doc.title,
          doc.summary,
          doc.category,
          doc.type,
          ...(doc.tags ?? []),
          ...(doc.aliases ?? []),
          doc.body,
        ].join(' ')).includes(normalizedQuery))
        .slice(0, 20);

      results.innerHTML = matched.length
        ? `<h2>検索結果 <span class="count">(${matched.length})</span></h2><ul>${matched.map((doc) => `
            <li>
              <a href="${makeUrl(`knowledge/${doc.slug}/`)}">${doc.title}</a>
              <span>${doc.summary ?? ''}</span>
            </li>
          `).join('')}</ul>`
        : '<p class="empty">該当するページはまだありません。</p>';
    };

    fetch(makeUrl('search.json'))
      .then((res) => res.json())
      .then((data) => {
        docs = data;
        const params = new URLSearchParams(window.location.search);
        renderResults(params.get('q') ?? input?.value ?? '');
      });

    input?.addEventListener('input', () => {
      renderResults(input.value);
    });
  </script>
</BaseLayout>
