---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDirectory, getSection, groupNotesByDirectory } from '../utils/knowledge';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => `${base}/${path}`.replace(/\/+/g, '/');
const issueUrl = 'https://github.com/isikoro1/isikoro-note/issues/new?title=%E7%9F%B3%E3%81%93%E3%82%8D%E3%83%8E%E3%83%BC%E3%83%88%E3%81%B8%E3%81%AE%E6%8C%87%E6%91%98&body=%E5%AF%BE%E8%B1%A1%E3%83%9A%E3%83%BC%E3%82%B8%3A%20%0A%0A%E6%8C%87%E6%91%98%E5%86%85%E5%AE%B9%3A%20%0A%0A%E5%8F%82%E8%80%83URL%3A%20';
const entries = Object.entries(import.meta.glob('../content/knowledge/**/*.md', { eager: true }));

const notes = entries
  .map(([path, mod]: [string, any]) => {
    const slug = path.replace('../content/knowledge/', '').replace(/\.md$/, '');
    return {
      slug,
      directory: getDirectory(slug),
      section: getSection(slug),
      ...mod.frontmatter,
    };
  })
  .sort((a: any, b: any) => String(a.title ?? '').localeCompare(String(b.title ?? ''), 'ja'));

const manualChildSlugs: Record<string, string[]> = {
  'tech/frontend/astro': [
    'tech/frontend/astro-adoption',
    'tech/frontend/why-this-site-uses-astro',
  ],
  'tech/frontend/react': [
    'tech/frontend/react-component',
    'tech/frontend/react-props',
    'tech/frontend/react-state',
    'tech/frontend/react-hooks',
    'tech/frontend/react-async',
  ],
  'tech/architecture/overview': [
    'tech/architecture/clean-architecture',
    'tech/architecture/layered-architecture',
    'tech/architecture/mvc',
    'tech/architecture/readable-code',
    'tech/development/ai-driven-development',
  ],
  'tech/programming-paradigm/overview': [
    'tech/programming-paradigm/procedural-programming',
    'tech/architecture/object-oriented-programming',
    'tech/programming-paradigm/functional-programming',
    'tech/programming-paradigm/declarative-programming',
    'tech/programming-paradigm/comparison',
  ],
  'tech/security/security': [
    'tech/security/authentication',
    'tech/security/authorization',
    'tech/security/xss',
    'tech/security/csrf',
    'tech/security/sql-injection',
    'tech/security/encryption',
    'tech/security/hashing',
  ],
};

const countChildPages = (note: any) => {
  if (note.slug === 'terms/overview') {
    return notes.filter((item: any) => item.directory === 'terms' && item.slug !== 'terms/overview' && item.listed !== false).length;
  }

  if (note.slug === 'reverse/overview') {
    return notes.filter((item: any) => item.slug !== 'reverse/overview' && item.listed !== false).length;
  }

  if (String(note.slug).endsWith('/overview')) {
    const root = String(note.slug).replace(/\/overview$/, '');
    const directChildren = notes.filter((item: any) => item.slug !== note.slug && String(item.slug).startsWith(`${root}/`)).length;
    const manualChildren = manualChildSlugs[note.slug] ?? [];
    return Math.max(directChildren, manualChildren.filter((slug) => notes.some((item: any) => item.slug === slug)).length);
  }

  const manualChildren = manualChildSlugs[note.slug] ?? [];
  if (manualChildren.length > 0) {
    return manualChildren.filter((slug) => notes.some((item: any) => item.slug === slug)).length;
  }

  return notes.filter((item: any) => item.slug !== note.slug && String(item.slug).startsWith(`${note.slug}/`)).length;
};

const groups = groupNotesByDirectory(notes as any).map((group) => ({
  ...group,
  notes: group.notes.map((note: any) => ({
    ...note,
    childCount: countChildPages(note),
  })),
}));
---
<BaseLayout title="石ころノート">
  <section class="notice-box">
    誤り指摘は、<a href={issueUrl} target="_blank" rel="noopener">GitHub Issues</a> から送信できます。
  </section>

  <section id="results" class="search-results" aria-live="polite"></section>

  <section class="index-sections">
    {groups.map((group) => (
      <section class="index-section">
        <h2>{group.section}</h2>
        <ul class="link-index">
          {group.notes.map((note: any) => (
            <li>
              <a href={url(`knowledge/${note.slug}/`)}>{note.title}</a>
              {note.childCount > 0 && (
                <span style="display: inline; color: var(--muted); white-space: nowrap; margin-left: 4px;">({note.childCount})</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>

  <script define:vars={{ base }}>
    const searchBase = `${base}/`.replace(/\/+/g, '/');
    const input = document.querySelector('#site-search');
    const form = input?.closest('form');
    const results = document.querySelector('#results');
    let docs = [];

    const normalize = (value) => String(value ?? '').toLowerCase();
    const makeUrl = (path) => `${searchBase}${path}`.replace(/\/+/g, '/');
    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
    const stripMarkdown = (value) => String(value ?? '')
      .replace(/^#+\s+/gm, '')
      .replace(/`([^`]+)`/g, '$1')
      .replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1')
      .replace(/[>*_\-]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
    const highlight = (text, query) => {
      const rawText = String(text ?? '');
      const rawQuery = String(query ?? '').trim();
      if (!rawQuery) return escapeHtml(rawText);

      const lowerText = rawText.toLowerCase();
      const lowerQuery = rawQuery.toLowerCase();
      let cursor = 0;
      let html = '';

      while (cursor < rawText.length) {
        const index = lowerText.indexOf(lowerQuery, cursor);
        if (index === -1) {
          html += escapeHtml(rawText.slice(cursor));
          break;
        }

        html += escapeHtml(rawText.slice(cursor, index));
        html += `<mark>${escapeHtml(rawText.slice(index, index + rawQuery.length))}</mark>`;
        cursor = index + rawQuery.length;
      }

      return html;
    };
    const findMatch = (doc, normalizedQuery) => {
      const fields = [
        { label: 'タイトル', value: doc.title },
        { label: '概要', value: doc.summary },
        { label: 'キーワード', value: [...(doc.keywords ?? []), ...(doc.tags ?? []), ...(doc.aliases ?? [])].join(' / ') },
        { label: '本文', value: stripMarkdown(doc.body) },
      ];

      for (const field of fields) {
        const text = String(field.value ?? '');
        const index = normalize(text).indexOf(normalizedQuery);
        if (index === -1) continue;

        const start = Math.max(0, index - 45);
        const end = Math.min(text.length, index + normalizedQuery.length + 70);
        const prefix = start > 0 ? '…' : '';
        const suffix = end < text.length ? '…' : '';
        const excerpt = `${prefix}${text.slice(start, end)}${suffix}`;

        return {
          label: field.label,
          excerpt,
        };
      }

      return null;
    };

    const renderResults = (query) => {
      const normalizedQuery = normalize(query).trim();
      if (!results || !normalizedQuery) {
        if (results) results.innerHTML = '';
        return;
      }

      const matched = docs
        .map((doc) => ({ doc, match: findMatch(doc, normalizedQuery) }))
        .filter((item) => item.match)
        .slice(0, 20);

      results.innerHTML = matched.length
        ? `<h2>検索結果 <span class="count">(${matched.length})</span></h2><ul>${matched.map(({ doc, match }) => `
            <li>
              <a href="${makeUrl(`knowledge/${doc.slug}/`)}">${escapeHtml(doc.title)}</a>
              <p class="search-hit-label">${escapeHtml(match.label)}でヒット</p>
              <p class="search-hit-snippet">${highlight(match.excerpt, query)}</p>
            </li>
          `).join('')}</ul>`
        : '<p class="empty">該当するページはまだありません。</p>';
    };

    const applySearch = (query, shouldUpdateUrl = true) => {
      const value = String(query ?? '').trim();
      renderResults(value);

      if (!shouldUpdateUrl) return;
      const nextUrl = new URL(window.location.href);
      if (value) {
        nextUrl.searchParams.set('q', value);
      } else {
        nextUrl.searchParams.delete('q');
      }
      window.history.replaceState({}, '', nextUrl);
    };

    fetch(makeUrl('search.json'))
      .then((res) => res.json())
      .then((data) => {
        docs = data;
        const params = new URLSearchParams(window.location.search);
        const initialQuery = params.get('q') ?? input?.value ?? '';
        if (input && initialQuery) input.value = initialQuery;
        applySearch(initialQuery, false);
      });

    input?.addEventListener('input', () => {
      applySearch(input.value);
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      applySearch(input?.value ?? '');
    });
  </script>
</BaseLayout>
