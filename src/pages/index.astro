---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDirectory, getSection, getRecentNotes, groupNotesByDirectory } from '../utils/knowledge';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => `${base}/${path}`.replace(/\/+/g, '/');
const issueUrl = 'https://github.com/isikoro1/isikoro-note/issues/new?title=%E7%9F%B3%E3%81%93%E3%82%8D%E3%83%86%E3%83%83%E3%82%AF%E3%83%9E%E3%83%83%E3%83%97%E3%81%B8%E3%81%AE%E6%8C%87%E6%91%98&body=%E5%AF%BE%E8%B1%A1%E3%83%9A%E3%83%BC%E3%82%B8%3A%20%0A%0A%E6%8C%87%E6%91%98%E5%86%85%E5%AE%B9%3A%20%0A%0A%E5%8F%82%E8%80%83URL%3A%20';
const entries = Object.entries(import.meta.glob('../content/knowledge/**/*.md', { eager: true }));

const notes = entries
  .map(([path, mod]: [string, any]) => {
    const slug = path.replace('../content/knowledge/', '').replace(/\.md$/, '');
    return {
      slug,
      directory: getDirectory(slug),
      section: getSection(slug),
      ...mod.frontmatter,
    };
  })
  .sort((a: any, b: any) => String(a.title ?? '').localeCompare(String(b.title ?? ''), 'ja'));

const groups = groupNotesByDirectory(notes as any);
const recentNotes = getRecentNotes(notes as any, 8);
---
<BaseLayout title="石ころ技術マップ">
  <section class="notice-box">
    誤り指摘は、<a href={issueUrl} target="_blank" rel="noopener">GitHub Issues</a> から送信できます。
  </section>

  <section id="results" class="link-index search-results" aria-live="polite"></section>

  <div class="top-tabs" data-tabs>
    <div class="tab-buttons" role="tablist" aria-label="トップ表示切り替え">
      <button class="tab-button is-active" type="button" role="tab" aria-selected="true" aria-controls="map-panel" data-tab="map">技術マップ</button>
      <button class="tab-button" type="button" role="tab" aria-selected="false" aria-controls="recent-panel" data-tab="recent">最近の更新</button>
    </div>

    <section id="map-panel" class="tab-panel is-active" role="tabpanel">
      <section class="index-sections">
        {groups.map((group) => (
          <section class="index-section">
            <h2>{group.section} <span class="count">({group.notes.length})</span></h2>
            <ul class="link-index">
              {group.notes.map((note: any) => (
                <li>
                  <a href={url(`knowledge/${note.slug}/`)}>{note.title}</a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </section>
    </section>

    <section id="recent-panel" class="tab-panel" role="tabpanel" hidden>
      {recentNotes.length > 0 && (
        <section class="index-section recent-section">
          <h2>最近の更新 <span class="count">({recentNotes.length})</span></h2>
          <ul class="recent-list">
            {recentNotes.map((note: any) => (
              <li>
                <time>{note.updated}</time>
                <a href={url(`knowledge/${note.slug}/`)}>{note.title}</a>
                <span>{note.section}</span>
              </li>
            ))}
          </ul>
        </section>
      )}
    </section>
  </div>

  <script define:vars={{ base }}>
    const searchBase = `${base}/`.replace(/\/+/g, '/');
    const input = document.querySelector('#site-search');
    const results = document.querySelector('#results');
    let docs = [];

    const normalize = (value) => String(value ?? '').toLowerCase();
    const makeUrl = (path) => `${searchBase}${path}`.replace(/\/+/g, '/');

    const renderResults = (query) => {
      const normalizedQuery = normalize(query).trim();
      if (!results || !normalizedQuery) {
        if (results) results.innerHTML = '';
        return;
      }

      const matched = docs
        .filter((doc) => normalize([
          doc.title,
          doc.summary,
          doc.category,
          doc.type,
          ...(doc.keywords ?? []),
          ...(doc.tags ?? []),
          ...(doc.aliases ?? []),
          doc.body,
        ].join(' ')).includes(normalizedQuery))
        .slice(0, 20);

      results.innerHTML = matched.length
        ? `<h2>検索結果 <span class="count">(${matched.length})</span></h2><ul>${matched.map((doc) => `
            <li>
              <a href="${makeUrl(`knowledge/${doc.slug}/`)}">${doc.title}</a>
            </li>
          `).join('')}</ul>`
        : '<p class="empty">該当するページはまだありません。</p>';
    };

    fetch(makeUrl('search.json'))
      .then((res) => res.json())
      .then((data) => {
        docs = data;
        const params = new URLSearchParams(window.location.search);
        renderResults(params.get('q') ?? input?.value ?? '');
      });

    input?.addEventListener('input', () => {
      renderResults(input.value);
    });

    const tabRoot = document.querySelector('[data-tabs]');
    const tabButtons = tabRoot?.querySelectorAll('[data-tab]') ?? [];
    const panels = {
      map: document.querySelector('#map-panel'),
      recent: document.querySelector('#recent-panel'),
    };

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const selected = button.dataset.tab;

        tabButtons.forEach((item) => {
          const isActive = item === button;
          item.classList.toggle('is-active', isActive);
          item.setAttribute('aria-selected', String(isActive));
        });

        Object.entries(panels).forEach(([key, panel]) => {
          const isActive = key === selected;
          panel?.classList.toggle('is-active', isActive);
          if (panel) panel.hidden = !isActive;
        });
      });
    });
  </script>
</BaseLayout>
