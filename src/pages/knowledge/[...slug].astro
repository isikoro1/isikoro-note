---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path = '') => `${base}/${path}`.replace(/\/+/g, '/');

export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/knowledge/**/*.md');

  return Object.keys(modules).map((path) => {
    const slug = path.replace('../../content/knowledge/', '').replace(/\.md$/, '');
    return {
      params: { slug },
      props: { path },
    };
  });
}

const { path } = Astro.props;
const modules = import.meta.glob('../../content/knowledge/**/*.md');
const loader = modules[path];
const page: any = await loader();
const { Content, frontmatter } = page;
---
<BaseLayout title={`${frontmatter.title} | 石ころ技術マップ`} description={frontmatter.summary}>
  <article class="article">
    <h1>{frontmatter.title}</h1>
    {frontmatter.summary && <p class="lead">{frontmatter.summary}</p>}

    {frontmatter.keywords?.length > 0 && (
      <section class="term-meta" aria-label="キーワード">
        <p>
          <strong>キーワード:</strong>{' '}
          {frontmatter.keywords.map((keyword: string, index: number) => (
            <span>{keyword}{index < frontmatter.keywords.length - 1 ? ' / ' : ''}</span>
          ))}
        </p>
      </section>
    )}

    <Content />

    {frontmatter.related?.length > 0 && (
      <section>
        <h2>関連項目</h2>
        <ul class="related-list">
          {frontmatter.related.map((item: any) => (
            <li><a href={url(`knowledge/${item.slug}/`)}>{item.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
