---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/knowledge/**/*.md');

  return Object.keys(modules).map((path) => {
    const slug = path.replace('../../content/knowledge/', '').replace(/\.md$/, '');
    return {
      params: { slug },
      props: { path },
    };
  });
}

const { path } = Astro.props;
const modules = import.meta.glob('../../content/knowledge/**/*.md');
const loader = modules[path];
const page: any = await loader();
const { Content, frontmatter } = page;
---
<BaseLayout title={`${frontmatter.title} | isikorog note`} description={frontmatter.summary}>
  <article class="article">
    <p class="meta">
      {frontmatter.category} / {frontmatter.type} / {frontmatter.status} / Updated: {frontmatter.updated}
    </p>
    <h1>{frontmatter.title}</h1>
    {frontmatter.summary && <p class="meta">{frontmatter.summary}</p>}

    {frontmatter.tags?.length > 0 && (
      <div class="badges">
        {frontmatter.tags.map((tag: string) => <span class="badge">{tag}</span>)}
      </div>
    )}

    <Content />

    {frontmatter.related?.length > 0 && (
      <section>
        <h2>関連ページ</h2>
        <ul class="related-list">
          {frontmatter.related.map((item: any) => (
            <li><a href={`${base}knowledge/${item.slug}/`}>{item.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
